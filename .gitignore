# Build output
build/
*.o
*.a
*.elf
*.bin
*.obj
*.so

# SDK build output (regenerated by build.sh)
/ps5-payload-sdk/install/

# Whitelist the vendored prebuilt static libs (needed to link the debugger
# without rebuilding keystone from source or running the SDK's libcxx.sh
# on every clean build).
!debugger/third_party/keystone/lib/libkeystone.a
!debugger/third_party/cxxrt/lib/*.a

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~
